generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Market {
  id          String         @id @default(cuid())
  name        String
  date        DateTime
  openTime    String
  closeTime   String
  location    String
  address     String
  description String?
  type        String         @default("SATURDAY_MARKET")
  status      String         @default("UPCOMING")
  orders       Order[]
  vendors      MarketVendor[]
  availability VendorAvailability[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Vendor {
  id                  String         @id @default(cuid())
  name                String
  displayName         String?
  slug                String         @unique
  description         String
  logoUrl             String?
  category            String
  isActive            Boolean        @default(true)
  contactPerson       String?
  email               String?        @unique
  phone               String?
  website             String?
  instagramHandle     String?
  facebookHandle      String?
  vendorType          String         @default("certified_farmer")
  businessDescription String?
  boothImageUrl       String?
  signupDate          DateTime?
  onlineOrdersEnabled Boolean        @default(false)
  hashedPassword      String?
  needsReview         Boolean        @default(false)
  venmoQrUrl          String?
  paypalQrUrl         String?
  zelleQrUrl          String?
  gpayQrUrl           String?
  applePayQrUrl       String?
  venmoLink           String?
  paypalLink          String?
  zelleLink           String?
  gpayLink            String?
  applePayLink        String?
  vendorNotes         String?
  onlineOrdersRequested Boolean @default(false)
  productImage1Url    String?
  productImage2Url    String?
  productImage3Url    String?
  monthlyFee          Int            @default(0)
  feeStatus           String         @default("FREE")
  products            Product[]
  orderItems          OrderItem[]
  markets             MarketVendor[]
  changeLogs          VendorChangeLog[]
  availability        VendorAvailability[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model MarketVendor {
  id        String  @id @default(cuid())
  marketId  String
  market    Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  boothSpace String?
  boothFee  Int?
  isPaid    Boolean @default(false)
  notes     String?

  @@unique([marketId, vendorId])
}

model VendorApplication {
  id                  String   @id @default(cuid())
  businessName        String
  contactPerson       String
  email               String
  phone               String?
  website             String?
  instagramHandle     String?
  facebookHandle      String?
  vendorType          String   @default("certified_farmer")
  productsDescription String?
  pricingDescription  String?
  businessDescription String?
  boothImageUrl       String?
  productPhoto1Url    String?
  productPhoto2Url    String?
  productPhoto3Url    String?
  productPhoto4Url    String?
  productPhoto5Url    String?
  insuranceDocUrl     String?
  taxDocUrl           String?
  status              String   @default("PENDING")
  adminNotes          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model VendorChangeLog {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  action    String
  changedBy String
  summary   String
  details   String?
  createdAt DateTime @default(now())
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Int
  imageUrl    String?
  unit        String
  category    String
  quantity    Int         @default(0)
  isAvailable Boolean     @default(true)
  vendorId    String
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerNotes   String?
  marketId        String
  market          Market      @relation(fields: [marketId], references: [id])
  items           OrderItem[]
  subtotal        Int
  paymentMethod   String
  paymentStatus   String      @default("PENDING")
  pickupStatus    String      @default("PENDING")
  stripeSessionId String?
  adminNotes      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  vendorId    String
  vendor      Vendor  @relation(fields: [vendorId], references: [id])
  quantity    Int
  priceAtTime Int
  productName String
  vendorName  String
}

model VendorAvailability {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  status    String   // SUBSTITUTE or UNAVAILABLE
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, marketId])
}
